---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import I18nScript from "../components/I18nScript.astro";
import CookieConsent from "../components/CookieConsent.astro";
import FormattedDate from "../components/FormattedDate.astro";
import TldrBlock from "../components/TldrBlock.astro";
import { CATEGORIES } from "../consts";

type Props = CollectionEntry<"insights">["data"];

const { title, description, pubDate, updatedDate, category, readingTime, tldr, heroImage, seoDescription } =
	Astro.props;
const categoryLabel = CATEGORIES.find((c) => c.slug === category)?.label ?? category;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={seoDescription ?? description} image={heroImage} />
	</head>
	<body>
		<Header />

		<!-- Hero image -->
		{heroImage && (
			<div class="hero-image">
				<img src={heroImage} alt="" />
			</div>
		)}

		<main>
			<article>
				<header class="article-header">
					<div class="article-meta">
						<a href={`/insights/?category=${category}`} class="badge">{categoryLabel}</a>
						<span class="meta-sep">·</span>
						<span class="meta"><FormattedDate date={pubDate} /></span>
						<span class="meta-sep">·</span>
						<span class="meta">{readingTime}</span>
					</div>
					<h1>{title}</h1>
					<p class="article-lead">{description}</p>
					{updatedDate && (
						<p class="updated meta">
							<span data-i18n="article.updated">Updated:</span> <FormattedDate date={updatedDate} />
						</p>
					)}
				</header>

				{tldr && tldr.length > 0 && <TldrBlock items={tldr} />}

				<div class="prose">
					<slot />
				</div>

				<footer class="article-footer">
					<hr class="divider" />
					<div class="newsletter-cta">
						<div class="cta-content">
							<h3 data-i18n="article.newsletter.title">Operator Letter</h3>
							<p data-i18n="article.newsletter.text">
								Monthly insights from the engine room — strategy, technology and operational perspectives.
							</p>
						</div>
						<a href="/newsletter" class="btn" data-i18n="article.newsletter.cta">Subscribe</a>
					</div>
				</footer>
			</article>
		</main>
		<Footer />
		<CookieConsent />
		<I18nScript />
	</body>
</html>

<style>
	/* Hero image */
	.hero-image {
		width: 100%;
		max-width: var(--max-width-wide);
		margin: 0 auto;
		padding: 0 1.5em;
	}

	.hero-image img {
		width: 100%;
		height: 420px;
		object-fit: cover;
		border-radius: 0 0 var(--radius-xl) var(--radius-xl);
	}

	/* Article */
	main {
		width: var(--max-width);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		padding: 3rem 1rem;
	}

	.article-header {
		text-align: center;
		margin-bottom: 3em;
		padding-top: 1em;
	}

	.article-meta {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5em;
		margin-bottom: 1.25em;
		flex-wrap: wrap;
	}

	.article-meta .badge {
		text-decoration: none;
	}

	.article-meta .badge:hover {
		text-decoration: none;
	}

	.meta-sep {
		color: var(--text-tertiary);
		font-size: 0.85em;
	}

	h1 {
		margin-bottom: 0.5em;
		line-height: 1.12;
		max-width: 14em;
		margin-left: auto;
		margin-right: auto;
	}

	.article-lead {
		color: var(--text-secondary);
		font-size: 1.2em;
		line-height: 1.65;
		max-width: 560px;
		margin: 0 auto;
	}

	.updated {
		margin-top: 0.75em;
		font-style: italic;
	}

	/* Footer / CTA */
	.article-footer {
		margin-top: 4em;
	}

	.newsletter-cta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2em;
		padding: 2em;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
	}

	.cta-content h3 {
		margin-bottom: 0.25em;
		font-size: 1.15em;
	}

	.cta-content p {
		color: var(--text-secondary);
		margin: 0;
		font-size: 0.925em;
		line-height: 1.5;
	}

	.newsletter-cta .btn {
		flex-shrink: 0;
	}

	/* Tablet */
	@media (max-width: 768px) {
		.hero-image img {
			height: 300px;
			border-radius: 0 0 var(--radius-lg) var(--radius-lg);
		}

		main {
			padding: 2em 1.25em;
		}

		h1 {
			font-size: 2em;
		}

		.article-lead {
			font-size: 1.05em;
		}
	}

	/* Mobile */
	@media (max-width: 480px) {
		.hero-image {
			padding: 0;
		}

		.hero-image img {
			height: 220px;
			border-radius: 0;
		}

		main {
			padding: 1.5em 1em;
		}

		h1 {
			font-size: 1.625em;
		}

		.article-header {
			margin-bottom: 2em;
			text-align: left;
		}

		.article-meta {
			justify-content: flex-start;
		}

		.article-lead {
			font-size: 1em;
		}

		.newsletter-cta {
			flex-direction: column;
			text-align: center;
			padding: 1.5em;
		}

		.newsletter-cta .btn {
			width: 100%;
		}
	}
</style>
