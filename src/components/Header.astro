---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.replace(/\/$/, "") || "/";

const nav = [
	{ href: "/", key: "nav.home", label: "Home" },
	{ href: "/insights", key: "nav.insights", label: "Insights" },
	{ href: "/focus", key: "nav.focus", label: "Focus" },
	{ href: "/about", key: "nav.about", label: "About" },
	{ href: "/newsletter", key: "nav.newsletter", label: "Newsletter" },
	{ href: "/contact", key: "nav.contact", label: "Contact" },
];
---

<header>
	<nav>
		<a href="/" class="logo">Florian Soter</a>

		<div class="nav-right">
			<ul>
				{nav.map(({ href, key, label }) => (
					<li>
						<a
							href={href}
							data-i18n={key}
							class:list={[{ active: href === "/" ? currentPath === "/" : currentPath.startsWith(href) }]}
						>
							{label}
						</a>
					</li>
				))}
			</ul>

			<!-- Social links -->
			<div class="social-links">
				<a href="https://x.com/FlorianSot64718" target="_blank" rel="noopener" aria-label="X / Twitter">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
				</a>
				<a href="https://www.linkedin.com/in/floriansoter/" target="_blank" rel="noopener" aria-label="LinkedIn">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
				</a>
				<a href="https://flosot.medium.com" target="_blank" rel="noopener" aria-label="Medium">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
				</a>
			</div>

			<!-- Language toggle -->
			<button id="lang-toggle" class="lang-toggle" type="button" onclick="window.__setLang(document.documentElement.getAttribute('data-lang')==='en'?'de':'en')">DE</button>

			<!-- Theme toggle -->
			<button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle theme">
				<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
				<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
			</button>

			<!-- Mobile toggle -->
			<input type="checkbox" id="nav-toggle" class="sr-only" />
			<label for="nav-toggle" class="nav-toggle-label" aria-label="Menu"><span></span></label>
		</div>
	</nav>
</header>

<script>
	function initThemeToggle() {
		const btn = document.getElementById("theme-toggle");
		if (!btn) return;
		btn.addEventListener("click", () => {
			const current = document.documentElement.getAttribute("data-theme");
			const next = current === "light" ? "dark" : "light";
			document.documentElement.setAttribute("data-theme", next);
			localStorage.setItem("theme", next);
		});
	}
	initThemeToggle();
	document.addEventListener("astro:after-swap", initThemeToggle);
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--glass-bg);
		backdrop-filter: saturate(180%) blur(20px);
		-webkit-backdrop-filter: saturate(180%) blur(20px);
		border-bottom: 1px solid var(--glass-border);
		transition: background 0.3s ease;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--max-width-wide);
		margin: 0 auto;
		padding: 0.875em 1.5em;
	}
	.logo {
		font-weight: 700;
		font-size: 1.05em;
		color: var(--text);
		text-decoration: none;
		letter-spacing: -0.02em;
		flex-shrink: 0;
	}
	.logo:hover { color: var(--text); text-decoration: none; }
	.nav-right {
		display: flex;
		align-items: center;
		gap: 1em;
	}

	/* Social links */
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}
	.social-links a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		color: var(--text-tertiary);
		border-radius: 50%;
		transition: all 0.2s ease;
		text-decoration: none;
	}
	.social-links a:hover {
		color: var(--text);
		background: var(--accent-soft);
		text-decoration: none;
	}

	/* Lang toggle */
	.lang-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 32px;
		padding: 0 0.65em;
		background: transparent;
		border: 1px solid var(--border-strong);
		border-radius: 980px;
		color: var(--text-secondary);
		cursor: pointer;
		font-size: 0.75em;
		font-weight: 700;
		font-family: inherit;
		letter-spacing: 0.03em;
		transition: all 0.2s ease;
	}
	.lang-toggle:hover {
		color: var(--text);
		border-color: var(--text-secondary);
	}

	/* Theme toggle */
	.theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		padding: 0;
		background: transparent;
		border: none;
		border-radius: 50%;
		color: var(--text-secondary);
		cursor: pointer;
		transition: all 0.2s ease;
		flex-shrink: 0;
	}
	.theme-toggle:hover {
		color: var(--text);
		background: var(--accent-soft);
	}
	.icon-sun { display: block; }
	.icon-moon { display: none; }
	:global([data-theme="light"]) .icon-sun { display: none; }
	:global([data-theme="light"]) .icon-moon { display: block; }

	/* Nav links */
	ul {
		display: flex;
		gap: 1.75em;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	ul a {
		color: var(--text-secondary);
		text-decoration: none;
		font-size: 0.875em;
		font-weight: 500;
		transition: color 0.2s ease;
		white-space: nowrap;
	}
	ul a:hover, ul a.active {
		color: var(--text);
		text-decoration: none;
	}

	/* Mobile hamburger */
	.nav-toggle-label {
		display: none;
		cursor: pointer;
		padding: 0.5em;
		min-width: 44px;
		min-height: 44px;
		align-items: center;
		justify-content: center;
	}
	.nav-toggle-label span,
	.nav-toggle-label span::before,
	.nav-toggle-label span::after {
		display: block;
		background: var(--text);
		height: 1.5px;
		width: 1.25em;
		position: relative;
		transition: all 0.25s ease;
	}
	.nav-toggle-label span::before,
	.nav-toggle-label span::after { content: ""; position: absolute; }
	.nav-toggle-label span::before { top: -6px; }
	.nav-toggle-label span::after { top: 6px; }

	@media (max-width: 960px) {
		ul { gap: 1.25em; }
		ul a { font-size: 0.825em; }
		.social-links { display: none; }
	}
	@media (max-width: 720px) {
		.nav-toggle-label { display: flex; }
		.nav-right { gap: 0.25em; }
		.social-links { display: none; }
		ul {
			display: none;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			flex-direction: column;
			gap: 0;
			background: var(--glass-bg);
			backdrop-filter: saturate(180%) blur(20px);
			-webkit-backdrop-filter: saturate(180%) blur(20px);
			border-bottom: 1px solid var(--glass-border);
			padding: 0.5em 1.5em 1em;
			z-index: 99;
		}
		ul li a { display: block; padding: 0.75em 0; font-size: 1em; min-height: 44px; }
		#nav-toggle:checked ~ ul { display: flex; }
		#nav-toggle:checked ~ .nav-toggle-label span { background: transparent; }
		#nav-toggle:checked ~ .nav-toggle-label span::before { top: 0; transform: rotate(45deg); }
		#nav-toggle:checked ~ .nav-toggle-label span::after { top: 0; transform: rotate(-45deg); }
	}
</style>
