---
interface Props {
	id: string;
	iframeId: string;
	closeId: string;
	iframeTitle: string;
}

const { id, iframeId, closeId, iframeTitle } = Astro.props;
---

<div class="modal-overlay" id={id} aria-hidden="true">
	<div class="modal-content">
		<button class="modal-close" id={closeId} aria-label="Close">
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<line x1="18" y1="6" x2="6" y2="18"></line>
				<line x1="6" y1="6" x2="18" y2="18"></line>
			</svg>
		</button>
		<iframe
			id={iframeId}
			width="540"
			height="520"
			frameborder="0"
			scrolling="auto"
			allowfullscreen
			title={iframeTitle}
		></iframe>
	</div>
</div>
