---
import FormattedDate from "./FormattedDate.astro";
import { CATEGORIES } from "../consts";

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	category: string;
	readingTime: string;
	slug: string;
	heroImage?: string;
	featured?: boolean;
}

const { title, description, pubDate, category, readingTime, slug, heroImage, featured = false } = Astro.props;
const categoryLabel = CATEGORIES.find((c) => c.slug === category)?.label ?? category;
---

<a href={`/insights/${slug}/`} class:list={["article-card", "card", { featured }]}>
	{heroImage && (
		<div class="card-image">
			<img src={heroImage} alt="" loading="lazy" />
		</div>
	)}
	<div class="card-body">
		<div class="card-meta">
			<span class="badge">{categoryLabel}</span>
			<span class="meta"><FormattedDate date={pubDate} /></span>
			<span class="meta">{readingTime}</span>
		</div>
		<h3>{title}</h3>
		<p>{description}</p>
	</div>
</a>

<style>
	.article-card {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
		padding: 0;
	}

	.article-card:hover {
		text-decoration: none;
		color: inherit;
	}

	.card-image {
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-radius: var(--radius-lg) var(--radius-lg) 0 0;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.article-card:hover .card-image img {
		transform: scale(1.03);
	}

	.card-body {
		padding: 1.5em;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.75em;
		margin-bottom: 0.75em;
		flex-wrap: wrap;
	}

	h3 {
		font-size: 1.2em;
		margin-bottom: 0.5em;
		line-height: 1.3;
		letter-spacing: -0.02em;
	}

	p {
		color: var(--text-secondary);
		margin: 0;
		font-size: 0.925em;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* Featured variant — horizontal layout on desktop */
	.featured {
		flex-direction: row;
	}

	.featured .card-image {
		width: 55%;
		flex-shrink: 0;
		aspect-ratio: auto;
		min-height: 280px;
		border-radius: var(--radius-lg) 0 0 var(--radius-lg);
	}

	.featured .card-body {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 2em;
	}

	.featured h3 {
		font-size: 1.5em;
	}

	.featured p {
		-webkit-line-clamp: 4;
	}

	@media (max-width: 768px) {
		.featured {
			flex-direction: column;
		}

		.featured .card-image {
			width: 100%;
			aspect-ratio: 16 / 9;
			min-height: auto;
			border-radius: var(--radius-lg) var(--radius-lg) 0 0;
		}

		.featured h3 {
			font-size: 1.25em;
		}
	}

	@media (max-width: 480px) {
		.card-body {
			padding: 1.25em;
		}

		h3 {
			font-size: 1.1em;
		}

		p {
			font-size: 0.875em;
		}
	}
</style>
