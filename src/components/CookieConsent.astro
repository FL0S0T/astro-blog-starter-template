---
import { translations } from "../i18n/translations";
const translationsJson = JSON.stringify({
	"cookie.text": translations["cookie.text"],
	"cookie.accept": translations["cookie.accept"],
	"cookie.decline": translations["cookie.decline"],
	"cookie.privacy": translations["cookie.privacy"],
});
---

<div id="cookie-banner" class="cookie-banner" style="display:none;" role="dialog" aria-label="Cookie consent">
	<div class="cookie-inner">
		<p class="cookie-text" data-i18n="cookie.text">This website uses cookies for analytics and functionality.</p>
		<div class="cookie-actions">
			<a href="/datenschutz" class="cookie-link" data-i18n="cookie.privacy">Privacy Policy</a>
			<button id="cookie-decline" class="btn btn-small btn-outline" data-i18n="cookie.decline">Decline</button>
			<button id="cookie-accept" class="btn btn-small" data-i18n="cookie.accept">Accept</button>
		</div>
	</div>
</div>

<script is:inline define:vars={{ translationsJson }}>
(function() {
	var T = JSON.parse(translationsJson);
	var banner = document.getElementById("cookie-banner");
	if (!banner) return;

	var consent = localStorage.getItem("cookie-consent");
	if (consent) return;

	banner.style.display = "";

	function applyLang() {
		var lang = localStorage.getItem("lang") || "en";
		banner.querySelectorAll("[data-i18n]").forEach(function(el) {
			var key = el.getAttribute("data-i18n");
			if (T[key] && T[key][lang]) el.textContent = T[key][lang];
		});
	}
	applyLang();

	var origSetLang = window.__setLang;
	if (origSetLang) {
		window.__setLang = function(lang) {
			origSetLang(lang);
			applyLang();
		};
	}

	document.getElementById("cookie-accept").addEventListener("click", function() {
		localStorage.setItem("cookie-consent", "accepted");
		banner.style.display = "none";
	});

	document.getElementById("cookie-decline").addEventListener("click", function() {
		localStorage.setItem("cookie-consent", "declined");
		banner.style.display = "none";
	});
})();
</script>

<style>
	.cookie-banner {
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		z-index: 9999;
		padding: 1em 1.5em;
		background: var(--bg-elevated);
		border-top: 1px solid var(--border);
		backdrop-filter: saturate(180%) blur(20px);
		-webkit-backdrop-filter: saturate(180%) blur(20px);
	}

	.cookie-inner {
		max-width: var(--max-width-wide);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5em;
	}

	.cookie-text {
		margin: 0;
		font-size: 0.875em;
		color: var(--text-secondary);
		line-height: 1.5;
	}

	.cookie-actions {
		display: flex;
		align-items: center;
		gap: 0.75em;
		flex-shrink: 0;
	}

	.cookie-link {
		font-size: 0.8em;
		color: var(--text-tertiary);
		text-decoration: none;
		white-space: nowrap;
	}

	.cookie-link:hover {
		color: var(--text-secondary);
		text-decoration: none;
	}

	.btn-small {
		font-size: 0.8em;
		padding: 0.4em 1em;
	}

	@media (max-width: 600px) {
		.cookie-inner {
			flex-direction: column;
			text-align: center;
			gap: 1em;
		}

		.cookie-actions {
			width: 100%;
			justify-content: center;
		}
	}
</style>
