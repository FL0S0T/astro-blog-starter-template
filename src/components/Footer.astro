---
const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<div class="footer-main">
			<div class="footer-brand">
				<a href="/" class="footer-logo">
					<svg width="24" height="24" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
						<rect x="2" y="2" width="24" height="24" rx="6" stroke="currentColor" stroke-width="1.75"/>
						<line x1="8" y1="9" x2="20" y2="9" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
						<line x1="8" y1="14" x2="16" y2="14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
						<line x1="8" y1="19" x2="13" y2="19" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
					</svg>
					Florian Soter
				</a>
				<p data-i18n="footer.tagline">Techie at heart. CEO by trade. Bridging code and business.</p>
			</div>
			<nav class="footer-nav">
				<div class="nav-col">
					<h4 data-i18n="footer.content">Content</h4>
					<a href="/insights">Insights</a>
					<a href="/focus">Focus</a>
					<a href="/newsletter">Newsletter</a>
				</div>
				<div class="nav-col">
					<h4 data-i18n="footer.more">More</h4>
					<a href="/about">About</a>
					<a href="/contact">Contact</a>
					<a href="/rss.xml">RSS Feed</a>
				</div>
			</nav>
		</div>
		<div class="footer-social">
			<a href="https://x.com/FlorianSot64718" target="_blank" rel="noopener" aria-label="X">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
			</a>
			<a href="https://www.linkedin.com/in/floriansoter/" target="_blank" rel="noopener" aria-label="LinkedIn">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
			</a>
			<a href="https://flosot.medium.com" target="_blank" rel="noopener" aria-label="Medium">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
			</a>
		</div>
		<div class="footer-bottom">
			<p>&copy; {year} Florian Soter</p>
			<div class="footer-legal">
				<a href="/impressum">Impressum</a>
				<a href="/datenschutz">Datenschutz</a>
			</div>
		</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		margin-top: 5em;
		background: var(--bg-elevated);
	}

	.footer-inner {
		max-width: var(--max-width-wide);
		margin: 0 auto;
		padding: 3em 1.5em 2em;
	}

	.footer-main {
		display: flex;
		justify-content: space-between;
		gap: 3em;
		padding-bottom: 2.5em;
		border-bottom: 1px solid var(--border);
		margin-bottom: 1.5em;
	}

	.footer-brand {
		max-width: 320px;
	}

	.footer-logo {
		font-weight: 700;
		font-size: 1.05em;
		color: var(--text);
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 0.5em;
		margin-bottom: 0.5em;
	}

	.footer-logo:hover {
		color: var(--text);
		text-decoration: none;
	}

	.footer-brand p {
		color: var(--text-tertiary);
		font-size: 0.875em;
		line-height: 1.5;
		margin: 0;
	}

	.footer-nav {
		display: flex;
		gap: 4em;
	}

	.nav-col {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}

	.nav-col h4 {
		font-size: 0.8em;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--text-secondary);
		margin-bottom: 0.25em;
	}

	.nav-col a {
		color: var(--text-tertiary);
		font-size: 0.875em;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.nav-col a:hover {
		color: var(--text);
		text-decoration: none;
	}

	.footer-social {
		display: flex;
		gap: 1em;
		padding: 1.5em 0;
		border-bottom: 1px solid var(--border);
		margin-bottom: 1.5em;
	}

	.footer-social a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border-radius: 50%;
		color: var(--text-tertiary);
		background: var(--surface);
		border: 1px solid var(--border);
		transition: all 0.2s ease;
		text-decoration: none;
	}

	.footer-social a:hover {
		color: var(--text);
		border-color: var(--border-strong);
		text-decoration: none;
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.footer-bottom p {
		margin: 0;
		color: var(--text-tertiary);
		font-size: 0.8em;
	}

	.footer-legal {
		display: flex;
		gap: 1.5em;
	}

	.footer-legal a {
		color: var(--text-tertiary);
		font-size: 0.8em;
		text-decoration: none;
	}

	.footer-legal a:hover {
		color: var(--text-secondary);
	}

	@media (max-width: 768px) {
		.footer-main {
			flex-direction: column;
			gap: 2em;
		}

		.footer-nav {
			gap: 3em;
		}
	}

	@media (max-width: 480px) {
		.footer-inner {
			padding: 2em 1em 1.5em;
		}

		.footer-bottom {
			flex-direction: column;
			gap: 0.75em;
			text-align: center;
		}
	}
</style>
