<style>
	main {
		width: var(--max-width);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		padding: 4rem 1rem 3rem;
	}

	.legal-content h1 {
		margin-bottom: 1.5em;
	}

	.legal-content h2 {
		margin-top: 2em;
		margin-bottom: 0.75em;
		font-family: "Inter", -apple-system, sans-serif;
	}

	.legal-content h3 {
		margin-top: 1.5em;
		margin-bottom: 0.5em;
		font-family: "Inter", -apple-system, sans-serif;
	}

	.legal-content p {
		color: var(--text-secondary);
		line-height: 1.7;
		margin-bottom: 1em;
	}

	.legal-content a {
		color: var(--accent);
	}

	.legal-content .meta {
		color: var(--text-tertiary);
		font-size: 0.9em;
		font-style: italic;
		margin-top: 2em;
	}

	@media (max-width: 480px) {
		main {
			padding: 2.5em 1em 2em;
		}
	}
</style>
