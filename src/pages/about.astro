---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import I18nScript from "../components/I18nScript.astro";
import CookieConsent from "../components/CookieConsent.astro";
---

<html lang="en">
	<head>
		<BaseHead
			title="About"
			description="Techie at heart. CEO by trade. I bridge deep technical understanding with real business problems to create solutions that actually work."
		/>
	</head>
	<body>
		<Header />

		<section class="page-hero" id="hero">
			<div class="hero-inner">
				<p class="hero-eyebrow" data-i18n="about.eyebrow">About</p>
				<h1 data-i18n="about.headline">Techie at Heart.<br />CEO by Trade.</h1>
			</div>
		</section>

		<main>
			<div class="about-grid">
				<div class="about-content prose">
					<div class="profile-section">
						<img src="/images/profilbild.jpeg" alt="Florian Soter" class="profile-photo" />
						<div>
							<p data-i18n="about.intro">
								I'm Florian Soter — a techie who became a CEO. I still write code, build cloud architectures and ship AI solutions. My edge: I bridge deep technical understanding with real business problems to create solutions that actually work.
							</p>
						</div>
					</div>

					<h2 data-i18n="about.background.title">Background</h2>
					<p data-i18n="about.background.p1">
						I've been a techie my whole life. I completed an apprenticeship, then studied Business Informatics (Wirtschaftsinformatik) at TU Darmstadt — and started working at consulting firms from my very first semester. The focus back then was already technology: strategy, architecture, implementation.
					</p>
					<p data-i18n="about.background.p2">
						Over the years, strategy and delivery came on top — M&A deals, tech due diligences, large-scale change programs, AI strategy development. I've introduced AI in highly regulated industries like energy, finance and insurance. But the techie never left. I still build, code and architect whenever I can.
					</p>

					<h2 data-i18n="about.what.title">What I do</h2>
					<p data-i18n="about.what.p1">
						I build cloud architectures, ship AI solutions and develop strategies that work — because I understand both sides. I love coding, cloud technology and the craft of turning complex problems into running systems. As CEO, I bring that deep technical understanding into business decisions, M&A processes and organizational design.
					</p>

					<h2 data-i18n="about.why.title">Why I write</h2>
					<p data-i18n="about.why.p1">
						Writing is thinking. If you can't structure ideas, you haven't truly understood them. This site is my thinking space — where I translate observations from operational practice into structural analyses.
					</p>
					<p data-i18n="about.why.p2">
						I write for CEOs, CTOs, investors and technical operators who don't just want to use technology, but understand it — in its strategic implications, not just its features.
					</p>

					<h2 data-i18n="about.drive.title">What drives me</h2>
					<p data-i18n="about.drive.p1">
						I create real value by bridging deep technical understanding with the real problems of people and businesses. Technology should be shaped by builders — not just described by observers. That means getting into the code, understanding the architecture, and building sustainable solutions.
					</p>
					<p data-i18n="about.drive.p2">
						As a father of two, I know how important clear systems are — in business as in life. That shapes how I think, build and write.
					</p>
				</div>

				<aside class="about-sidebar">
					<div class="sidebar-card surface">
						<h3 data-i18n="about.contact.title">Contact</h3>
						<p data-i18n="about.contact.text">
							I enjoy strategic conversations with like-minded people.
						</p>
						<a href="/contact" class="btn" data-i18n="about.contact.cta">Start a conversation</a>
					</div>

					<div class="sidebar-card surface">
						<h3 data-i18n="about.newsletter.title">Operator Letter</h3>
						<p data-i18n="about.newsletter.text">
							Monthly insights — strategy, technology, operational perspectives.
						</p>
						<a href="/newsletter" class="btn btn-outline" data-i18n="about.newsletter.cta">Subscribe</a>
					</div>
				</aside>
			</div>
		</main>
		<Footer />
		<CookieConsent />
		<I18nScript />
	</body>
</html>

<style>
	.page-hero {
		--mx: 0.5;
		--my: 0.5;
		background: var(--gradient-hero);
		padding: 5em 1.5em 4em;
		text-align: center;
		position: relative;
		overflow: hidden;
		isolation: isolate;
	}

	.page-hero::before,
	.page-hero::after {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		will-change: background;
	}

	.page-hero::before {
		background: radial-gradient(
			600px circle at calc(var(--mx) * 100%) calc(var(--my) * 100%),
			rgba(79, 124, 255, 0.18) 0%,
			transparent 70%
		);
	}

	.page-hero::after {
		background: radial-gradient(
			500px circle at calc(var(--mx) * 100% + 80px) calc(var(--my) * 100% - 60px),
			rgba(99, 66, 255, 0.12) 0%,
			transparent 70%
		);
	}

	:global([data-theme="light"]) .page-hero::before {
		background: radial-gradient(
			600px circle at calc(var(--mx) * 100%) calc(var(--my) * 100%),
			rgba(0, 113, 227, 0.22) 0%,
			transparent 70%
		);
	}

	:global([data-theme="light"]) .page-hero::after {
		background: radial-gradient(
			500px circle at calc(var(--mx) * 100% + 80px) calc(var(--my) * 100% - 60px),
			rgba(120, 100, 220, 0.15) 0%,
			transparent 70%
		);
	}

	@media (hover: none) {
		.page-hero::before {
			background: radial-gradient(600px circle at 50% 50%, rgba(79, 124, 255, 0.15) 0%, transparent 70%);
			animation: nebula-drift-1 8s ease-in-out infinite alternate;
		}
		.page-hero::after {
			background: radial-gradient(500px circle at 50% 50%, rgba(99, 66, 255, 0.10) 0%, transparent 70%);
			animation: nebula-drift-2 10s ease-in-out infinite alternate;
		}
		:global([data-theme="light"]) .page-hero::before {
			background: radial-gradient(600px circle at 50% 50%, rgba(0, 113, 227, 0.18) 0%, transparent 70%);
		}
		:global([data-theme="light"]) .page-hero::after {
			background: radial-gradient(500px circle at 50% 50%, rgba(120, 100, 220, 0.12) 0%, transparent 70%);
		}
	}

	@keyframes nebula-drift-1 {
		0%   { transform: translate(-8%, -5%); }
		100% { transform: translate(8%, 5%); }
	}

	@keyframes nebula-drift-2 {
		0%   { transform: translate(6%, 8%); }
		100% { transform: translate(-6%, -8%); }
	}

	@media (prefers-reduced-motion: reduce) {
		.page-hero::before,
		.page-hero::after {
			animation: none !important;
			transform: none !important;
		}
	}

	.hero-inner {
		max-width: 600px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.hero-eyebrow {
		display: inline-block;
		padding: 0.35em 1em;
		background: var(--accent-soft);
		border-radius: 980px;
		font-size: 0.85em;
		font-weight: 600;
		color: var(--accent);
		margin-bottom: 1.25em;
	}

	.hero-inner h1 {
		font-size: 3em;
		letter-spacing: -0.04em;
	}

	main {
		width: var(--max-width-wide);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		padding: 3rem 1rem;
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 4em;
		align-items: start;
	}

	.profile-section {
		display: flex;
		gap: 1.75em;
		align-items: flex-start;
		margin-bottom: 1em;
	}

	.profile-photo {
		width: 140px;
		height: 140px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
		border: 3px solid var(--border);
	}

	.about-content h2 {
		font-family: "Inter", -apple-system, sans-serif;
	}

	.about-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.5em;
		position: sticky;
		top: 5em;
	}

	.sidebar-card {
		text-align: center;
	}

	.sidebar-card h3 {
		margin-bottom: 0.5em;
		font-size: 1.1em;
	}

	.sidebar-card p {
		color: var(--text-secondary);
		font-size: 0.9em;
		line-height: 1.55;
		margin-bottom: 1.25em;
	}

	@media (max-width: 768px) {
		.page-hero {
			padding: 3.5em 1.25em 3em;
		}

		.hero-inner h1 {
			font-size: 2.25em;
		}

		.about-grid {
			grid-template-columns: 1fr;
			gap: 2.5em;
		}

		.about-sidebar {
			position: static;
			flex-direction: row;
		}

		.sidebar-card {
			flex: 1;
		}
	}

	@media (max-width: 480px) {
		.page-hero {
			padding: 2.5em 1em 2em;
			text-align: left;
		}

		.hero-inner h1 {
			font-size: 1.75em;
		}

		.hero-inner h1 br {
			display: none;
		}

		.profile-section {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}

		.profile-photo {
			width: 120px;
			height: 120px;
		}

		.about-sidebar {
			flex-direction: column;
		}
	}
</style>

<script>
	function initHeroNebula() {
		const hero = document.getElementById("hero");
		if (!hero) return;

		const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		const hasHover = window.matchMedia("(hover: hover)").matches;

		if (prefersReducedMotion || !hasHover) return;

		let targetX = 0.5;
		let targetY = 0.5;
		let currentX = 0.5;
		let currentY = 0.5;
		let rafId: number | null = null;

		function onMouseMove(e: MouseEvent) {
			const rect = hero!.getBoundingClientRect();
			targetX = (e.clientX - rect.left) / rect.width;
			targetY = (e.clientY - rect.top) / rect.height;
		}

		function animate() {
			currentX += (targetX - currentX) * 0.04;
			currentY += (targetY - currentY) * 0.04;
			hero!.style.setProperty("--mx", currentX.toFixed(4));
			hero!.style.setProperty("--my", currentY.toFixed(4));
			rafId = requestAnimationFrame(animate);
		}

		const observer = new IntersectionObserver(
			([entry]) => {
				if (entry.isIntersecting) {
					hero!.addEventListener("mousemove", onMouseMove);
					if (!rafId) rafId = requestAnimationFrame(animate);
				} else {
					hero!.removeEventListener("mousemove", onMouseMove);
					if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
				}
			},
			{ threshold: 0 }
		);

		observer.observe(hero);
	}

	initHeroNebula();
	document.addEventListener("astro:after-swap", initHeroNebula);
</script>
