---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroNebula from "../components/HeroNebula.astro";
import I18nScript from "../components/I18nScript.astro";
import CookieConsent from "../components/CookieConsent.astro";
---

<html lang="en">
	<head>
		<BaseHead
			title="About"
			description="Techie at heart. CEO by trade. I bridge deep technical understanding with real business problems to create solutions that actually work."
		/>
	</head>
	<body>
		<Header />

		<section class="page-hero hero-nebula" id="hero">
			<div class="hero-inner">
				<p class="hero-eyebrow" data-i18n="about.eyebrow">About</p>
				<h1 data-i18n="about.headline">Techie at Heart.<br />CEO by Trade.</h1>
			</div>
		</section>

		<main>
			<div class="about-grid">
				<div class="about-content prose">
					<div class="profile-section">
						<img src="/images/profilbild.jpeg" alt="Florian Soter" class="profile-photo" />
						<div>
							<p data-i18n="about.intro">
								I'm Florian Soter — a techie who became a CEO. I still write code, build cloud architectures and ship AI solutions. My edge: I bridge deep technical understanding with real business problems to create solutions that actually work.
							</p>
						</div>
					</div>

					<h2 data-i18n="about.background.title">Background</h2>
					<p data-i18n="about.background.p1">
						I've been a techie my whole life. I completed an apprenticeship, then studied Business Informatics (Wirtschaftsinformatik) at TU Darmstadt — and started working at consulting firms from my very first semester. The focus back then was already technology: strategy, architecture, implementation.
					</p>
					<p data-i18n="about.background.p2">
						Over the years, strategy and delivery came on top — M&A deals, tech due diligences, large-scale change programs, AI strategy development. I've introduced AI in highly regulated industries like energy, finance and insurance. But the techie never left. I still build, code and architect whenever I can.
					</p>

					<h2 data-i18n="about.what.title">What I do</h2>
					<p data-i18n="about.what.p1">
						I build cloud architectures, ship AI solutions and develop strategies that work — because I understand both sides. I love coding, cloud technology and the craft of turning complex problems into running systems. As CEO, I bring that deep technical understanding into business decisions, M&A processes and organizational design.
					</p>

					<h2 data-i18n="about.ventures.title">Ventures</h2>
					<p data-i18n="about.ventures.intro">
						I build companies at the intersection of technology and business.
					</p>
					<div class="ventures-list">
						<a href="https://grayoak.de" target="_blank" rel="noopener" class="venture-card surface">
							<div class="venture-header">
								<span class="venture-name">GrayOak</span>
								<span class="venture-role badge" data-i18n="about.ventures.grayoak.role">Co-Founder & CEO</span>
							</div>
							<p data-i18n="about.ventures.grayoak.desc">
								Technology consulting and AI implementation for enterprises. We help organizations turn AI strategy into operational reality.
							</p>
						</a>
					</div>

					<h2 data-i18n="about.why.title">Why I write</h2>
					<p data-i18n="about.why.p1">
						Writing is thinking. If you can't structure ideas, you haven't truly understood them. This site is my thinking space — where I translate observations from operational practice into structural analyses.
					</p>
					<p data-i18n="about.why.p2">
						I write for CEOs, CTOs, investors and technical operators who don't just want to use technology, but understand it — in its strategic implications, not just its features.
					</p>

					<h2 data-i18n="about.drive.title">What drives me</h2>
					<p data-i18n="about.drive.p1">
						I create real value by bridging deep technical understanding with the real problems of people and businesses. Technology should be shaped by builders — not just described by observers. That means getting into the code, understanding the architecture, and building sustainable solutions.
					</p>
					<p data-i18n="about.drive.p2">
						As a father of two, I know how important clear systems are — in business as in life. That shapes how I think, build and write.
					</p>

					<h2 data-i18n="about.personal.title">Beyond work</h2>
					<p data-i18n="about.personal.p1">
						Married, father of two. When I'm not building products or writing code, I'm most likely on a mountain bike, a road bike, or in the mountains. CrossFit keeps me grounded during the week. And good food is non-negotiable — cooking and eating with people I care about is where I recharge.
					</p>
				</div>

				<aside class="about-sidebar">
					<div class="sidebar-card surface">
						<h3 data-i18n="about.contact.title">Contact</h3>
						<p data-i18n="about.contact.text">
							I enjoy strategic conversations with like-minded people.
						</p>
						<a href="/contact" class="btn" data-i18n="about.contact.cta">Start a conversation</a>
					</div>

					<div class="sidebar-card surface">
						<h3 data-i18n="about.newsletter.title">Operator Letter</h3>
						<p data-i18n="about.newsletter.text">
							Monthly insights — strategy, technology, operational perspectives.
						</p>
						<a href="/newsletter" class="btn btn-outline" data-i18n="about.newsletter.cta">Subscribe</a>
					</div>
				</aside>
			</div>
		</main>
		<Footer />
		<CookieConsent />
		<I18nScript />
		<HeroNebula />
	</body>
</html>

<style>
	.hero-inner {
		max-width: 600px;
	}

	.hero-inner h1 {
		font-size: 3em;
		letter-spacing: -0.04em;
	}

	main {
		width: var(--max-width-wide);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		padding: 3rem 1rem;
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 4em;
		align-items: start;
	}

	.profile-section {
		display: flex;
		gap: 1.75em;
		align-items: flex-start;
		margin-bottom: 1em;
	}

	.profile-photo {
		width: 140px;
		height: 140px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
		border: 3px solid var(--border);
	}

	.about-content h2 {
		font-family: "Inter", -apple-system, sans-serif;
	}

	.ventures-list {
		display: flex;
		flex-direction: column;
		gap: 1em;
		margin-bottom: 2em;
	}

	.venture-card {
		display: block;
		padding: 1.5em;
		text-decoration: none;
		color: var(--text);
		transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
	}

	.venture-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-lg);
		border-color: var(--border-strong);
		text-decoration: none;
		color: var(--text);
	}

	.venture-header {
		display: flex;
		align-items: center;
		gap: 0.75em;
		margin-bottom: 0.5em;
	}

	.venture-name {
		font-family: "Inter", -apple-system, sans-serif;
		font-weight: 700;
		font-size: 1.1em;
		letter-spacing: -0.02em;
	}

	.venture-role {
		font-size: 0.75em;
	}

	.venture-card p {
		color: var(--text-secondary);
		font-size: 0.9em;
		margin-bottom: 0;
		line-height: 1.6;
	}

	.about-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.5em;
		position: sticky;
		top: 5em;
	}

	.sidebar-card {
		text-align: center;
	}

	.sidebar-card h3 {
		margin-bottom: 0.5em;
		font-size: 1.1em;
	}

	.sidebar-card p {
		color: var(--text-secondary);
		font-size: 0.9em;
		line-height: 1.55;
		margin-bottom: 1.25em;
	}

	@media (max-width: 768px) {
		.hero-inner h1 {
			font-size: 2.25em;
		}

		.about-grid {
			grid-template-columns: 1fr;
			gap: 2.5em;
		}

		.about-sidebar {
			position: static;
			flex-direction: row;
		}

		.sidebar-card {
			flex: 1;
		}
	}

	@media (max-width: 480px) {
		.hero-inner h1 {
			font-size: 1.75em;
		}

		.hero-inner h1 br {
			display: none;
		}

		.profile-section {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}

		.profile-photo {
			width: 120px;
			height: 120px;
		}

		.about-sidebar {
			flex-direction: column;
		}
	}
</style>
