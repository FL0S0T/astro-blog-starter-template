---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import I18nScript from "../../components/I18nScript.astro";
import CookieConsent from "../../components/CookieConsent.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { CATEGORIES } from "../../consts";
import { getCollection } from "astro:content";

const PAGE_SIZE = 12;
const allPosts = await getCollection("insights");
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<html lang="en">
	<head>
		<BaseHead
			title="Insights"
			description="Strategische Analysen, operative Einblicke und strukturelles Denken im KI-Zeitalter."
		/>
	</head>
	<body>
		<Header />
		<main class="wide">
			<section class="page-header">
				<h1 data-i18n="insights.title">Insights</h1>
				<p class="text-secondary" data-i18n="insights.sub">
					Structural analyses and operational perspectives — organized by five thinking layers.
				</p>
			</section>

			<!-- Category filter -->
			<section class="filters">
				<button class="badge active" data-category="all" data-i18n="insights.all">All</button>
				{CATEGORIES.map((cat) => (
					<button class="badge" data-category={cat.slug}>{cat.label}</button>
				))}
			</section>

			<!-- Articles -->
			<section class="article-grid">
				{sortedPosts.map((post, i) => (
					<div
						class="article-item"
						data-category={post.data.category}
						data-index={i}
						style={i >= PAGE_SIZE ? "display:none" : undefined}
					>
						<ArticleCard
							title={post.data.title}
							description={post.data.description}
							pubDate={post.data.pubDate}
							category={post.data.category}
							readingTime={post.data.readingTime}
							slug={post.id}
							heroImage={post.data.heroImage}
						/>
					</div>
				))}
			</section>

			<!-- Load more -->
			<div class="load-more-container" id="load-more-container">
				<div class="scroll-sentinel" id="scroll-sentinel" aria-hidden="true"></div>
				<button class="btn btn-outline load-more-btn" id="load-more-btn" data-i18n="insights.loadMore">
					Load more
				</button>
				<span class="sr-only" aria-live="polite" id="load-more-status"></span>
			</div>
		</main>
		<Footer />
		<CookieConsent />
		<I18nScript />

		<script>
			function initInsights() {
				const PAGE_SIZE = 12;
				const buttons = document.querySelectorAll<HTMLButtonElement>(".filters .badge");
				const allItems = Array.from(document.querySelectorAll<HTMLElement>(".article-item"));
				const container = document.getElementById("load-more-container")!;
				const sentinel = document.getElementById("scroll-sentinel")!;
				const loadMoreBtn = document.getElementById("load-more-btn")!;
				const status = document.getElementById("load-more-status")!;
				const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

				let activeCategory = "all";
				let visibleCount = PAGE_SIZE;

				function getFilteredItems(): HTMLElement[] {
					return allItems.filter(
						(item) => activeCategory === "all" || item.dataset.category === activeCategory,
					);
				}

				function applyVisibility(animate = false) {
					const filtered = getFilteredItems();
					let shown = 0;

					allItems.forEach((item) => {
						const matchesCategory = activeCategory === "all" || item.dataset.category === activeCategory;
						if (matchesCategory && shown < visibleCount) {
							item.style.display = "";
							shown++;
						} else {
							item.style.display = "none";
						}
					});

					// Show/hide load more
					const hasMore = filtered.length > visibleCount;
					container.style.display = hasMore ? "" : "none";

					// Update screen reader status
					status.textContent = `${shown} of ${filtered.length} articles shown.`;
				}

				function animateBatch(startIndex: number, count: number) {
					if (prefersReducedMotion) return;
					const filtered = getFilteredItems();
					const batch = filtered.slice(startIndex, startIndex + count);
					batch.forEach((item, i) => {
						item.style.setProperty("--stagger", String(i));
						item.classList.add("card-reveal");
					});
				}

				function loadMore() {
					const filtered = getFilteredItems();
					const prevCount = visibleCount;
					visibleCount = Math.min(visibleCount + PAGE_SIZE, filtered.length);
					applyVisibility();
					animateBatch(prevCount, visibleCount - prevCount);
				}

				function setFilter(category: string) {
					activeCategory = category;
					visibleCount = PAGE_SIZE;

					buttons.forEach((btn) => {
						btn.classList.toggle("active", btn.dataset.category === category);
					});

					applyVisibility();

					// Animate initial batch on filter change
					animateBatch(0, Math.min(PAGE_SIZE, getFilteredItems().length));
				}

				// Clean up animation class after it finishes
				document.querySelector(".article-grid")?.addEventListener("animationend", (e) => {
					(e.target as HTMLElement).closest?.(".article-item")?.classList.remove("card-reveal");
				});

				// IntersectionObserver for auto-loading
				const observer = new IntersectionObserver(
					(entries) => {
						if (entries[0]?.isIntersecting) {
							loadMore();
						}
					},
					{ rootMargin: "200px" },
				);
				observer.observe(sentinel);

				// Load More button click
				loadMoreBtn.addEventListener("click", () => {
					loadMore();
					loadMoreBtn.focus();
				});

				// Filter button clicks
				buttons.forEach((btn) => {
					btn.addEventListener("click", () => {
						const cat = btn.dataset.category || "all";
						setFilter(cat);
						const url = new URL(window.location.href);
						if (cat === "all") {
							url.searchParams.delete("category");
						} else {
							url.searchParams.set("category", cat);
						}
						history.replaceState(null, "", url.toString());
					});
				});

				// Initialize from URL
				const params = new URLSearchParams(window.location.search);
				const initialCategory = params.get("category") || "all";
				setFilter(initialCategory);
			}

			initInsights();
			document.addEventListener("astro:after-swap", initInsights);
		</script>
	</body>
</html>

<style>
	.page-header {
		margin-bottom: 2em;
		max-width: 560px;
	}

	.page-header h1 {
		margin-bottom: 0.5em;
	}

	.filters {
		display: flex;
		gap: 0.5em;
		flex-wrap: wrap;
		margin-bottom: 2.5em;
	}

	.filters .badge {
		cursor: pointer;
		font-family: inherit;
		padding: 0.4em 1em;
		min-height: 36px;
		transition: all 0.2s ease;
	}

	.filters .badge:hover:not(.active) {
		background: var(--surface-hover);
	}

	.article-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5em;
	}

	.load-more-container {
		display: flex;
		flex-direction: column;
		align-items: center;
		margin-top: 2em;
	}

	.scroll-sentinel {
		width: 1px;
		height: 1px;
		pointer-events: none;
	}

	.load-more-btn {
		min-width: 160px;
	}

	@media (max-width: 768px) {
		.article-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 480px) {
		.filters .badge {
			font-size: 0.78em;
			padding: 0.35em 0.75em;
		}

		.filters {
			margin-bottom: 1.5em;
		}
	}
</style>
