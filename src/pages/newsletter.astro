---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import I18nScript from "../components/I18nScript.astro";
import CookieConsent from "../components/CookieConsent.astro";
---

<html lang="en">
	<head>
		<BaseHead
			title="Newsletter"
			description="Der Operator Letter — monatliche Einblicke aus dem Maschinenraum. Strategie, Technologie und operative Perspektiven."
		/>
	</head>
	<body>
		<Header />

		<section class="page-hero" id="hero">
			<div class="hero-inner">
				<p class="hero-eyebrow" data-i18n="newsletter.eyebrow">Newsletter</p>
				<h1 data-i18n="newsletter.title">Operator Letter</h1>
				<p class="hero-sub" data-i18n="newsletter.sub">
					Once a month. Straight from the engine room.
					Strategic reflections and operational insights.
				</p>
			</div>
		</section>

		<main class="wide">
			<div class="newsletter-grid">
				<div class="info">
					<div class="info-block">
						<h2 data-i18n="newsletter.what.title">What is the Operator Letter?</h2>
						<p data-i18n="newsletter.what.text">
							A monthly letter with strategic reflections, operational insights and current experiments. Written from the perspective of an active builder — not from theory.
						</p>
					</div>

					<div class="info-block">
						<h2 data-i18n="newsletter.who.title">For whom?</h2>
						<p data-i18n="newsletter.who.text">
							For CEOs, CTOs, investors and technical operators who think about technology structurally and not just as a tool.
						</p>
					</div>

					<div class="info-block">
						<h2 data-i18n="newsletter.get.title">What do you get?</h2>
						<div class="feature-list">
							<div class="feature-item">
								<span class="feature-icon">01</span>
								<span data-i18n="newsletter.get.1">Summary of the most important article of the month</span>
							</div>
							<div class="feature-item">
								<span class="feature-icon">02</span>
								<span data-i18n="newsletter.get.2">Personal reflection from operational practice</span>
							</div>
							<div class="feature-item">
								<span class="feature-icon">03</span>
								<span data-i18n="newsletter.get.3">Current experiments and tests</span>
							</div>
							<div class="feature-item">
								<span class="feature-icon">04</span>
								<span data-i18n="newsletter.get.4">1–2 external recommendations</span>
							</div>
						</div>
					</div>
				</div>

				<div class="signup-wrapper">
					<div class="signup-card surface">
						<h3 data-i18n="newsletter.signup.title">Subscribe now</h3>
						<p class="text-secondary">
							<span data-i18n="newsletter.signup.text">No hype. No marketing.<br />Structural perspectives from practice.</span>
						</p>
						<form>
							<input
								type="email"
								placeholder="Your email address" data-i18n-placeholder="newsletter.signup.placeholder"
								required
								aria-label="Email address"
							/>
							<button type="submit" class="btn" data-i18n="newsletter.signup.cta">Subscribe</button>
						</form>
						<p class="privacy-note text-tertiary" data-i18n="newsletter.signup.privacy">
							Once a month. Unsubscribe anytime. No tracking.
						</p>
					</div>
				</div>
			</div>
		</main>
		<Footer />
		<CookieConsent />
		<I18nScript />
	</body>
</html>

<style>
	.page-hero {
		--mx: 0.5;
		--my: 0.5;
		background: var(--gradient-hero);
		padding: 5em 1.5em 4em;
		text-align: center;
		position: relative;
		overflow: hidden;
		isolation: isolate;
	}

	.page-hero::before,
	.page-hero::after {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		will-change: background;
	}

	.page-hero::before {
		background: radial-gradient(
			600px circle at calc(var(--mx) * 100%) calc(var(--my) * 100%),
			rgba(79, 124, 255, 0.18) 0%,
			transparent 70%
		);
	}

	.page-hero::after {
		background: radial-gradient(
			500px circle at calc(var(--mx) * 100% + 80px) calc(var(--my) * 100% - 60px),
			rgba(99, 66, 255, 0.12) 0%,
			transparent 70%
		);
	}

	:global([data-theme="light"]) .page-hero::before {
		background: radial-gradient(
			600px circle at calc(var(--mx) * 100%) calc(var(--my) * 100%),
			rgba(0, 113, 227, 0.22) 0%,
			transparent 70%
		);
	}

	:global([data-theme="light"]) .page-hero::after {
		background: radial-gradient(
			500px circle at calc(var(--mx) * 100% + 80px) calc(var(--my) * 100% - 60px),
			rgba(120, 100, 220, 0.15) 0%,
			transparent 70%
		);
	}

	@media (hover: none) {
		.page-hero::before {
			background: radial-gradient(600px circle at 50% 50%, rgba(79, 124, 255, 0.15) 0%, transparent 70%);
			animation: nebula-drift-1 8s ease-in-out infinite alternate;
		}
		.page-hero::after {
			background: radial-gradient(500px circle at 50% 50%, rgba(99, 66, 255, 0.10) 0%, transparent 70%);
			animation: nebula-drift-2 10s ease-in-out infinite alternate;
		}
		:global([data-theme="light"]) .page-hero::before {
			background: radial-gradient(600px circle at 50% 50%, rgba(0, 113, 227, 0.18) 0%, transparent 70%);
		}
		:global([data-theme="light"]) .page-hero::after {
			background: radial-gradient(500px circle at 50% 50%, rgba(120, 100, 220, 0.12) 0%, transparent 70%);
		}
	}

	@keyframes nebula-drift-1 {
		0%   { transform: translate(-8%, -5%); }
		100% { transform: translate(8%, 5%); }
	}

	@keyframes nebula-drift-2 {
		0%   { transform: translate(6%, 8%); }
		100% { transform: translate(-6%, -8%); }
	}

	@media (prefers-reduced-motion: reduce) {
		.page-hero::before,
		.page-hero::after {
			animation: none !important;
			transform: none !important;
		}
	}

	.hero-inner {
		max-width: 560px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.hero-eyebrow {
		display: inline-block;
		padding: 0.35em 1em;
		background: var(--accent-soft);
		border-radius: 980px;
		font-size: 0.85em;
		font-weight: 600;
		color: var(--accent);
		margin-bottom: 1.25em;
	}

	.hero-sub {
		color: var(--text-secondary);
		font-size: 1.15em;
		line-height: 1.65;
	}

	/* Grid */
	.newsletter-grid {
		display: grid;
		grid-template-columns: 1fr 380px;
		gap: 4em;
		align-items: start;
	}

	/* Info */
	.info-block {
		margin-bottom: 2.5em;
	}

	.info-block h2 {
		font-size: 1.25em;
		margin-bottom: 0.5em;
	}

	.info-block p {
		color: var(--text-secondary);
		line-height: 1.7;
	}

	.feature-list {
		display: flex;
		flex-direction: column;
		gap: 0.75em;
	}

	.feature-item {
		display: flex;
		align-items: flex-start;
		gap: 1em;
		color: var(--text-secondary);
		line-height: 1.55;
	}

	.feature-icon {
		flex-shrink: 0;
		font-size: 0.75em;
		font-weight: 700;
		color: var(--accent);
		font-variant-numeric: tabular-nums;
		padding-top: 0.2em;
	}

	/* Signup card */
	.signup-wrapper {
		position: sticky;
		top: 5em;
	}

	.signup-card {
		padding: 2.5em;
	}

	.signup-card h3 {
		margin-bottom: 0.5em;
		text-align: center;
	}

	.signup-card > p {
		text-align: center;
		margin-bottom: 1.5em;
		font-size: 0.95em;
	}

	form {
		display: flex;
		flex-direction: column;
		gap: 0.75em;
		margin-bottom: 1em;
	}

	form .btn {
		width: 100%;
	}

	.privacy-note {
		text-align: center;
		font-size: 0.8em;
		margin: 0;
	}

	@media (max-width: 768px) {
		.page-hero {
			padding: 3.5em 1.25em 3em;
		}

		.newsletter-grid {
			grid-template-columns: 1fr;
			gap: 2.5em;
		}

		.signup-wrapper {
			position: static;
		}
	}

	@media (max-width: 480px) {
		.page-hero {
			padding: 2.5em 1em 2em;
			text-align: left;
		}

		.hero-sub {
			font-size: 1em;
		}

		.signup-card {
			padding: 1.5em;
		}
	}
</style>

<script>
	function initHeroNebula() {
		const hero = document.getElementById("hero");
		if (!hero) return;

		const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		const hasHover = window.matchMedia("(hover: hover)").matches;

		if (prefersReducedMotion || !hasHover) return;

		let targetX = 0.5;
		let targetY = 0.5;
		let currentX = 0.5;
		let currentY = 0.5;
		let rafId: number | null = null;

		function onMouseMove(e: MouseEvent) {
			const rect = hero!.getBoundingClientRect();
			targetX = (e.clientX - rect.left) / rect.width;
			targetY = (e.clientY - rect.top) / rect.height;
		}

		function animate() {
			currentX += (targetX - currentX) * 0.04;
			currentY += (targetY - currentY) * 0.04;
			hero!.style.setProperty("--mx", currentX.toFixed(4));
			hero!.style.setProperty("--my", currentY.toFixed(4));
			rafId = requestAnimationFrame(animate);
		}

		const observer = new IntersectionObserver(
			([entry]) => {
				if (entry.isIntersecting) {
					hero!.addEventListener("mousemove", onMouseMove);
					if (!rafId) rafId = requestAnimationFrame(animate);
				} else {
					hero!.removeEventListener("mousemove", onMouseMove);
					if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
				}
			},
			{ threshold: 0 }
		);

		observer.observe(hero);
	}

	initHeroNebula();
	document.addEventListener("astro:after-swap", initHeroNebula);
</script>
